# Database
DATABASE_URL=postgresql://user:password@localhost:5432/paraiso_astral

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Firebase Admin (prefer FIREBASE_SERVICE_ACCOUNT_JSON in production)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"..."}

# Optional SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=replace_me

# Optional Cloudinary
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Bootstrap admin (local one-time setup only)
BOOTSTRAP_ADMIN_EMAIL=admin@example.com

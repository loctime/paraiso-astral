# Public frontend variables (safe to expose)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:yourappid
VITE_API_BASE_URL=http://localhost:4000

# Local backend URL used by scripts (do not use production credentials here)
DATABASE_URL=postgresql://user:password@localhost:5432/paraiso_astral

# Optional media upload (backend uses CLOUDINARY_URL)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function isAdmin() {
      return request.auth != null
        && request.auth.token.admin == true;
    }

    // ═══════════════════════════════════════════════════════════════
    // EVENTS — lectura pública (landing site), escritura solo admin
    // ═══════════════════════════════════════════════════════════════
    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // ARTISTS — lectura pública, escritura solo admin
    // ═══════════════════════════════════════════════════════════════
    match /artists/{artistId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // SITE CONFIG — un solo doc ("main"), lectura pública, escritura admin
    // ═══════════════════════════════════════════════════════════════
    match /siteConfig/{configId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════
    // Cualquier otra colección → denegado por defecto.
    // Si en el futuro reactivás features sociales (chats, followers, etc.),
    // agregá las reglas acá. El histórico previo está en el commit anterior.
    // ═══════════════════════════════════════════════════════════════
  }
}
